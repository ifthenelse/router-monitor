{
  "folders": [
    {
      "path": ".",
    },
  ],
  "settings": {
    "search.useIgnoreFiles": true,
    "search.useGlobalIgnoreFiles": true,
    "files.exclude": {
      "**/.git": true,
      "**/.svn": true,
      "**/.hg": true,
      "**/CVS": true,
      "**/.DS_Store": true,
    },
    "search.exclude": {
      "**/target": true,
      "**/cargo.lock": true,
      "**/coverage": true,
      "**/logs": true,
      "**/*.log": true,
      "**/.env": true,
      "**/.env.local": true,
      "**/.env.*.local": true,
      "jobfit/data": true,
      "**/*.csv": true,
    },
    "files.watcherExclude": {
      "**/target/**": true,
      "**/cargo.lock": true,
      "**/coverage/**": true,
      "**/logs/**": true,
      "jobfit/data/**": true,
      "**/.env": true,
      "**/.env.local": true,
      "**/.env.*.local": true,
      "**/*.csv": true,
    },
    "specstory.cloudSync.enabled": "never",
  },
}
